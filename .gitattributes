## .gitattributes - Specify files to encrypt using git-crypt

# Encrypt terraform variables
home.tfplan filter=git-crypt diff=git-crypt
*.tfvar filter=git-crypt diff=git-crypt

# Encrypt any .key file
*.key filter=git-crypt diff=git-crypt

# Secret files folder
secrets/**/* filter=git-crypt diff=git-crypt

# Storage backend access keys
backend/backend-config.txt filter=git-crypt diff=git-crypt

# Never encrypt .gitattributes (keep as the very last line!)
.gitattributes !filter !diff
